#:import toast kivymd.toast.toast
<SecondScreen>:

    name : 'opt_screen'
    canvas:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            size: self.size
            pos: self.pos
    NavigationBar:

    MDFloatLayout:
        MDFlatButton:
            adaptive_size: True
            text: 'Назад'
            font_size: 18
            on_release:
                app.root.current='main_screen'
        MDBoxLayout:
            adaptive_size: True
            orientation: 'vertical'
            pos_hint:{'y':.5,'x':.675}
            size_hint:.325,.5
            MDRaisedButton:
                adaptive_size: True
                id: isofield_modes
                text: "Режим"
                on_release: app.menu.open()
            MDBoxLayout:
                id: field_top_right
                daptive_size: True
        MDBoxLayout:
            pos_hint:{'y':.5,'x':.35}
            size_hint:.325,.5
            MDBoxLayout:
                id: field_top_left
                daptive_size: True
        MDBoxLayout:
            id: field_bottom_right
            pos_hint:{'y':0,'x':.675}
            size_hint:.325,.5
        MDBoxLayout:
            id: field_bottom_left
            pos_hint:{'y':0,'x':.35}
            size_hint:.325,.5

        MDBoxLayout:
            id: panel
            orientation: 'vertical'
            adaptive_size: True
            pos_hint:{'top':.7,'x':0}
            canvas:
                Color:
                    rgba: 0.5, 1, 1, 1
                Rectangle:
                    size: self.size
                    pos: self.pos
            MDLabel:
                adaptive_size: True
                font_size: 24
                text: 'Общие сведения'
            MDBoxLayout:
                adaptive_size: True
                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Ветровой район'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Климатическая карта России]'
                MDFlatButton:
                    text: 'Выбор'
                    font_size: 18
            MDBoxLayout:
                adaptive_size: True
                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Тип местности'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Описание]'
                MDFlatButton:
                    text: 'Выбор'
                    font_size: 18
            MDBoxLayout:
                padding: '10dp'
                adaptive_size: True
                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Угол атака ветра (RUMB)'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Описание]'
                MDTextField:
                    id: RUMB
                    hint_text: 'RUMB'
                    helper_text: "углы кратные 5"
                    text: '0' ######
                    helper_text_mode: "on_focus"
                    font_size: 18
                    mode: "rectangle"
                    size_hint_x: None
                    width: 75
                    on_text_validate:
                        app.get_RUMB()

            MDBoxLayout:
                adaptive_size: True
                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Размеры здания'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Пояснения]'
                MDTextField:
                    id: model_size
                    hint_text: 'X Y Z'
                    helper_text: "через пробел"
                    text:'0.1 0.1 0.1' ######
                    helper_text_mode: "on_focus"
                    font_size: 18
                    mode: "rectangle"
                    size_hint_x: None
                    width: 75
                    on_text_validate:
                        app.get_size()
            MDBoxLayout:
                adaptive_size: True
                MDLabel:
                    adaptive_size: True
                    font_size: 18
                    text: 'Параметры интегрирования по высоте'
                MDFlatButton:
                    text: 'Поверхность'
                    font_size: 18
            MDFlatButton:
                text: 'Интегрирование по высоте'
                font_size: 18
            MDFlatButton:
                text: 'Поверхность интегрирования'
                font_size: 18
            MDFlatButton:
                text: 'Шаг сканирования (шаг интегрирования)'
                font_size: 18
            MDFlatButton:
                text: 'Экспорт'
                font_size: 24
            MDBoxLayout:
                adaptive_size: True
                MDLabel:
                    adaptive_size: True
                    font_size: 18
                    text: 'Нормативный документ'
                MDFlatButton:
                    text: 'СП20.13330.2016'
                    font_size: 18