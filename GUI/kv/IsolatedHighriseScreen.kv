#:import toast kivymd.toast.toast
<IsolatedHighriseScreen>:
    name : 'opt_screen'
    canvas:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            size: self.size
            pos: self.pos
    NavigationBar:

        MDFlatButton:
            adaptive_size: True
            text: 'Назад'
            on_release:
                app.root.current='main_screen'

    MDBoxLayout:
        orientation: 'horizontal'

        # панель управления
        MDScrollView
            pos_hint:{'top':.8,'x':0}
            size_hint:.35,1
            MDGridLayout:
                cols: 2
                adaptive_size: True
                spacing:10
                padding:8

                MDLabel:
                    adaptive_size: True
                    font_size: 24
                    text: 'Общие сведения'
                    mg_bg_color: (0.24, 0.59, 0.98, 1)
                MDFlatButton:
                    disabled: True

                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Ветровой район'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Климатическая карта России]'
                MDFlatButton:
                    text: 'Выбор'
                    font_size: 18

                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Тип местности'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Описание]'
                MDFlatButton:
                    text: 'Выбор'
                    font_size: 18


                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Угол атака ветра (RUMB)'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Описание]'

                MDTextField:
                    id: RUMB
                    hint_text: 'RUMB'
                    helper_text: "углы кратные 5"
                    text: '0' ######
                    helper_text_mode: "on_focus"
                    font_size: 18
                    mode: "rectangle"
                    size_hint_x: None
                    width: 75
                    on_text_validate:
                        app.get_RUMB()

                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Размеры здания'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Пояснения]'
                MDTextField:
                    id: model_size
                    hint_text: 'X Y Z'
                    helper_text: "через пробел"
                    text:'0.1 0.1 0.1' ######
                    helper_text_mode: "on_focus"
                    font_size: 18
                    mode: "rectangle"
                    size_hint_x: None
                    width: 75
                    on_text_validate:
                        app.get_size()

                MDLabel:
                    adaptive_size: True
                    font_size: 18
                    text: 'Альфа'
                MDTextField:
                    id: alpha
                    text:'6' ######
                    helper_text_mode: "on_focus"
                    font_size: 18
                    mode: "rectangle"
                    size_hint_x: None
                    width: 75
                    on_text_validate:
                        app.get_alpha()

                MDLabel:
                    adaptive_size: True
                    font_size: 18
                    text: 'Параметры интегрирования\n по высоте'
                MDFlatButton:
                    disabled: True

                MDFlatButton:
                    text: 'Интегрирование по высоте'
                    font_size: 18
                MDFlatButton:
                    disabled: True

                MDFlatButton:
                    text: 'Поверхность интегрирования'
                    font_size: 18
                MDFlatButton:
                    disabled: True

                MDFlatButton:
                    text: 'Поверхность'
                    font_size: 18
                MDFlatButton:
                    disabled: True

                MDFlatButton:
                    text: 'Шаг интегрирования'
                    font_size: 18
                MDFlatButton:
                    disabled: True

                MDLabel:
                    adaptive_size: True
                    font_size: 18
                    text: 'Нормативный документ'
                MDFlatButton:
                    text: 'СП20.13330.2016'
                    font_size: 18

                MDFlatButton:
                    text: 'Экспорт'
                    font_size: 18
        MDGridLayout:
            cols: 2
            # top left plot
            MDBoxLayout:
                adaptive_size: True
                orientation: 'vertical'
                size_hint:.325,1
                MDRaisedButton:
                    adaptive_size: True
                    id: button_plot_top_left
                    text: "Режим"
                    on_release: app.dropdownmenu_top_left.open()

                MDBoxLayout:
                    id: plot_top_left

            # top right plot
            MDBoxLayout:
                adaptive_size: True
                orientation: 'vertical'
                size_hint:.325,1
                MDRaisedButton:
                    adaptive_size: True
                    id: button_plot_top_right
                    text: "Режим"
                    on_release: app.dropdownmenu_top_right.open()
                MDBoxLayout:
                    id: plot_top_right

            # bottom left plot
            MDBoxLayout:
                adaptive_size: True
                orientation: 'vertical'
                size_hint:.325,1
                MDBoxLayout:
                    adaptive_size: True
                    orientation:'horizontal'
                    MDRaisedButton:
                        adaptive_size: True
                        id: button_plot_button_left_1
                        text: "Суммарные"
                        on_release: app.dropdownmenu_bottom_left_1.open()
                    MDRaisedButton:
                        adaptive_size: True
                        id: button_plot_button_left_2
                        text: "Масштаб"
                        on_release: app.dropdownmenu_bottom_left_2.open()
                    MDRectangleFlatButton:
                        text: "График"
                        on_release: app.bottom_left_plot()
                MDBoxLayout:
                    id: plot_bottom_left

            # bottom right plot
            MDBoxLayout:
                adaptive_size: True
                orientation: 'vertical'
                size_hint:.325,1
                MDBoxLayout:
                    adaptive_size: True
                    orientation:'horizontal'
                    MDRaisedButton:
                        adaptive_size: True
                        id: button_plot_button_right_1
                        text: "Суммарные"
                        on_release: app.dropdownmenu_bottom_right_1.open()
                    MDRectangleFlatButton:
                        text: "График"
                        on_release: app.bottom_right_plot()
                MDBoxLayout:
                    id: plot_bottom_right
