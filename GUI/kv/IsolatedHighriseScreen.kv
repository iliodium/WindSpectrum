#:import toast kivymd.toast.toast
<IsolatedHighriseScreen>:
    name : 'IsolatedHighriseScreen_screen'
    canvas:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            size: self.size
            pos: self.pos

    MDBoxLayout:
        orientation:'vertical'
        spacing:8
        NavigationBar:
            MDFlatButton:
                adaptive_size: True
                text: 'Назад'
                on_release:
                    app.root.current='main_screen'

        # панель управления
        MDScrollView:
            MDGridLayout:
                cols: 2
                adaptive_size: True
                spacing:10
                padding:8

                MDLabel:
                    adaptive_size: True
                    font_size: 24
                    text: 'Общие сведения'
                    mg_bg_color: (0.24, 0.59, 0.98, 1)
                MDFlatButton:
                    disabled: True

                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Ветровой район'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Климатическая карта России]'
                MDFlatButton:
                    text: 'Выбор'
                    font_size: 18

                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Тип местности'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Описание]'
                MDFlatButton:
                    text: 'Выбор'
                    font_size: 18


                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Угол атака ветра (RUMB)'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Описание]'

                MDTextField:
                    id: angle
                    hint_text: 'RUMB'
                    helper_text: "углы кратные 5"
                    text: '0' ######
                    helper_text_mode: "on_focus"
                    font_size: 18
                    mode: "rectangle"
                    size_hint_x: None
                    width: 75
                    on_text_validate:
                        app.get_angle()

                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Размеры здания'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Пояснения]'
                MDTextField:
                    id: model_size
                    hint_text: 'X Y Z'
                    helper_text: "через пробел"
                    text:'0.1 0.1 0.1' ######
                    helper_text_mode: "on_focus"
                    font_size: 18
                    mode: "rectangle"
                    size_hint_x: None
                    width: 150
                    on_text_validate:
                        app.get_size()

                MDLabel:
                    adaptive_size: True
                    font_size: 18
                    text: 'Альфа'
                MDTextField:
                    id: alpha
                    text:'6' ######
                    helper_text_mode: "on_focus"
                    font_size: 18
                    mode: "rectangle"
                    size_hint_x: None
                    width: 75
                    on_text_validate:
                        app.get_alpha()

                MDLabel:
                    adaptive_size: True
                    font_size: 18
                    text: 'Параметры интегрирования по высоте'
                MDFlatButton:
                    disabled: True

                MDFlatButton:
                    text: 'Интегрирование по высоте'
                    font_size: 18
                MDFlatButton:
                    disabled: True

                MDFlatButton:
                    text: 'Поверхность интегрирования'
                    font_size: 18
                MDFlatButton:
                    disabled: True

                MDFlatButton:
                    text: 'Поверхность'
                    font_size: 18
                MDFlatButton:
                    disabled: True

                MDFlatButton:
                    text: 'Шаг интегрирования'
                    font_size: 18
                MDFlatButton:
                    disabled: True

                MDLabel:
                    adaptive_size: True
                    font_size: 18
                    text: 'Нормативный документ'
                MDFlatButton:
                    text: 'СП20.13330.2016'
                    font_size: 18

                MDFlatButton:
                    text: 'Отчет'
                    font_size: 18
                    on_release:
                        app.report()
                MDFlatButton:
                    disabled: True

                MDRaisedButton:
                    adaptive_size: True
                    id: plots
                    font_size: 18
                    text: 'Графики'
                    on_release:
                        app.menu.open()
                MDFlatButton:
                    id: plots_fa
                    disabled: True
    MDFlatButton:
        disabled: True
        id: dropmenu_pos_1
        x: root.ids.plots.x + 256 + root.ids.plots.width / 2 - root.ids.dropmenu_pos_1.width / 2
        y: root.ids.plots.y + root.ids.plots.height / 2 - root.ids.dropmenu_pos_1.height / 2

    MDFlatButton:
        disabled: True
        id: dropmenu_pos_2
        x: root.ids.dropmenu_pos_1.x + 256 + root.ids.plots.width / 2 - root.ids.dropmenu_pos_2.width / 2
        y: root.ids.dropmenu_pos_1.y + 100#+ root.ids.plots.height / 2