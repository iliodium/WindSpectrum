<NavigationBar>
    adaptive_size: True
    pos_hint:{'top':1,'x':0}
    canvas:
        Color:
            rgba: 0.24, 0.59, 0.98, 1
        Rectangle:
            size: self.size
            pos: self.pos
    MDDropDownItem:
        id: nav_item_file
        text: 'Файл'
    MDDropDownItem:
        id: nav_item_mode
        text: 'Режим'
    MDDropDownItem:
        id: nav_item_settings
        text: 'Настройка'
    MDDropDownItem:
        id: nav_item_doc
        text: 'Справка'
    MDDropDownItem:
        id: nav_item_info
        text: 'О программе'