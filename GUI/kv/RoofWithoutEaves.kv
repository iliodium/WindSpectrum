#:import toast kivymd.toast.toast
#:import ScrollEffect  kivy.effects.scroll.ScrollEffect


<RoofWithoutEaves>:
    id: RoofWithoutEaves_screen
    name : 'RoofWithoutEaves_screen'

    canvas:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            size: self.size
            pos: self.pos

    MDBoxLayout:
        orientation:'vertical'
        spacing:8
        NavigationBar:
            MDFlatButton:
                adaptive_size: True
                text: 'Назад'
                on_release:
                    root.manager.current = 'Home_screen'

        MDScrollView:
            do_scroll_x: False
            scroll_wheel_distance:40
            effect_cls: ScrollEffect
            MDGridLayout:
                cols: 2
                adaptive_size: True
                spacing:10
                padding:8

                MDLabel:
                    adaptive_size: True
                    font_size: 24
                    text: 'Общие сведения'
                    mg_bg_color: (0.24, 0.59, 0.98, 1)
                MDFlatButton:
                    disabled: True

                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Ветровой район'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Климатическая карта России]'

                MDFlatButton:
                    id: wind_region_button
                    text: 'Iа'
                    font_size: 18
                    on_release:
                        root.drop_down_menu_wind_regions.open()

                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Тип местности'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Описание]'
                MDFlatButton:
                    id: type_area_button
                    text: 'A'
                    font_size: 18
                    on_release:
                        root.drop_down_menu_types_areas.open()

                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Размеры здания'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Пояснения]'

                MDTextField:
                    id: model_size
                    hint_text: 'X Y Z'
                    helper_text: "через пробел"
                    text:'10 10 10'
                    helper_text_mode: "on_focus"
                    font_size: 18
                    mode: "rectangle"
                    size_hint_x: None
                    width: 150

                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_size: True
                    MDLabel:
                        adaptive_size: True
                        font_size: 18
                        text: 'Угол атака ветра (RUMB)'
                    MDLabel:
                        adaptive_size: True
                        font_size: 10
                        font_style: 'Caption'
                        text: '[Описание]'

                MDRaisedButton:
                    adaptive_size: True
                    id: angle
                    font_size: 18
                    text: 'Угол'
                    on_release:
                        root.drop_down_menu_plots.open()

                MDLabel:
                    adaptive_size: True
                    font_size: 18
                    text: 'Тип крыши'

                MDRaisedButton:
                    adaptive_size: True
                    id: roof_type
                    font_size: 18
                    text: 'Тип крыши'
                    on_release:
                        root.hide_widget(root.ids.roof_angle, root.ids.roof_angle_label)

                MDLabel:
                    adaptive_size: True
                    id: roof_angle_label
                    font_size: 18
                    text: 'Угол крыши'

                MDRaisedButton:
                    adaptive_size: True
                    id: roof_angle
                    font_size: 18
                    text: 'Угол крыши'
                    disabled: True if root._roof_type == 'flat' else False

                MDLabel:
                    adaptive_size: True
                    font_size: 18
                    text: 'Нормативный документ'
                MDFlatButton:
                    text: 'СП20.13330.2016'
                    font_size: 18

                MDRaisedButton:
                    adaptive_size: True
                    id: plots
                    font_size: 18
                    text: 'Графики'
                    on_release:
                        root.drop_down_menu_plots.open()
                MDFlatButton:
                    disabled: True

                MDRaisedButton:
                    id: report_button
                    text: 'Отчет'
                    font_size: 18
                    on_release:
                        #app.screen_for_report = 'InterferenceHighriseScreen_screen'
                        root.manager.current = 'ReportContent_screen'

                MDSpinner:
                    id: report_spinner
                    size_hint: None, None
                    size: dp(46), dp(46)
                    active: False