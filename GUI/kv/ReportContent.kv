#:import ScrollEffect  kivy.effects.scroll.ScrollEffect

<ReportContent>:
    name : 'ReportContent_screen'

    MDBoxLayout:
        orientation:'vertical'
        spacing:8
        NavigationBar:
            MDFlatButton:
                adaptive_size: True
                text: 'Назад'
                on_release:
                    root.manager.current = app.screen_for_report

        MDRaisedButton:
            id: report_button
            text: 'Отчет'
            font_size: 18
            on_release:
                root.report(app.screen_for_report)
                root.manager.current = app.screen_for_report

        MDRaisedButton:
            id: chose_all_content
            text: 'Выбрать все'
            font_size: 18
            on_release:
                root.chose_all_content()

        MDScrollView:
            do_scroll_x: False
            scroll_wheel_distance:40
            effect_cls: ScrollEffect

            MDGridLayout:
                id: menu_layout
                cols: 2
                adaptive_width:True
                adaptive_height:True
                padding: [3,5,0,0]
