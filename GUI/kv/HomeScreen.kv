<HomeScreen>:
    id: home_screen
    name : 'Home_screen'

    canvas:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            size: self.size
            pos: self.pos

    MDBoxLayout:

        orientation: 'vertical'
        spacing:8

        NavigationBar:

        MDScrollView:
            do_scroll_x: False
            scroll_wheel_distance:40
            effect_cls: ScrollEffect
            MDGridLayout:
                cols:1
                adaptive_size: True

                # Расчеты ветровых нагрузок и воздействий
                MDLabel:
                    adaptive_size: True
                    text: 'Расчеты ветровых нагрузок и воздействий'
                    font_size: 18
                    md_bg_color: (0.24, 0.59, 0.98, 1)
                MDFlatButton:
                    text: 'Изолированное высотное здание'
                    font_size: 18
                    on_release:
                        root.manager.current = 'IsolatedHighriseScreen_screen'

                MDFlatButton:
                    text: 'Аэродинамическая интерференция высотных зданий'
                    font_size: 18
                MDFlatButton:
                    text: 'Изолированные низкоэтажные здания'
                    font_size: 18
                MDFlatButton:
                    text: 'Аэродинамическая интерференция низкоэтажных зданий'
                    font_size: 18

            # Динамический отклик
                MDLabel:
                    adaptive_size: True
                    text: 'Динамический отклик'
                    font_size: 18
                    md_bg_color:(0.24, 0.59, 0.98, 1)
                MDFlatButton:
                    text: 'Интегральные параметры здания'
                    font_size: 18
                MDFlatButton:
                    text: 'Матрицы Суперэлементов'
                    font_size: 18
                MDFlatButton:
                    text: 'Динамические гасители колебаний'
                    font_size: 18
                MDFlatButton:
                    text: 'Конвертер ветровых нагрузок в CAE'
                    font_size: 18

            # Инженерные калькуляторы
                MDLabel:
                    adaptive_size: True
                    text: 'Инженерные калькуляторы'
                    font_size: 18
                    md_bg_color:(0.24, 0.59, 0.98, 1)
                MDFlatButton:
                    text: 'Спектры'
                    font_size: 18
                MDFlatButton:
                    text: 'Интерполяционные табличные функции (изополя)'
                    font_size: 18
                MDFlatButton:
                    text: 'Преобразование единиц измерений'
                    font_size: 18
                MDFlatButton:
                    text: 'Калькулятор y+ (CFD)'
                    font_size: 18

            # Информация
                MDLabel:
                    adaptive_size: True
                    text: 'Информация'
                    font_size: 18
                    md_bg_color:(0.24, 0.59, 0.98, 1)
                MDFlatButton:
                    text: 'Климатические карты'
                    font_size: 18
                MDFlatButton:
                    text: 'Рекомендуемые публикации'
                    font_size: 18
                MDFlatButton:
                    text: 'Рекомендуемые ссылки'
                    font_size: 18